# Copy to .env and fill in. NEVER commit your real .env.
#
# Deployer key — a TESTNET-ONLY key with Pharos testnet PHRS for gas.
# Get gas from the faucet: https://testnet.pharosnetwork.xyz
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HERE

# Pharos Testnet RPC (chain id 688688)
RPC=https://testnet.dplabs-internal.com

# Optional: API key for contract verification on pharosscan / socialscan.
PHAROS_SCAN_API_KEY=
